# Copy to .env and fill in. The backend reads these on startup.

# Which LLM provider the /chat module uses: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Database (default: local SQLite file at ../data/jarvis.db)
DATABASE_URL=sqlite:///./data/jarvis.db

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000
